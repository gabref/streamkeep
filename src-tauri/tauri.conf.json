{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Streamkeep",
  "version": "0.1.0",
  "identifier": "app.streamkeep.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev:web",
    "beforeBuildCommand": "pnpm run prepare:android && pnpm run build-only"
  },
  "app": {
    "windows": [
      {
        "title": "Streamkeep",
        "width": 420,
        "height": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
