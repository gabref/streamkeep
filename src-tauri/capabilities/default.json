{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Default Streamkeep application permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "streamkeep-capture:allow-register-listener",
    "streamkeep-capture:allow-registerListener",
    "streamkeep-capture:allow-remove-listener",
    "streamkeep-capture:allow-removeListener",
    "streamkeep-capture:allow-openUri",
    "streamkeep-capture:allow-publishToDownloads",
    "streamkeep-capture:allow-remuxToMp4"
  ]
}
