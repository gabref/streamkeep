{
  "name": "streamkeep",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev": "node scripts/with-windows-sdk.mjs tauri dev --config src-tauri/tauri.dev.conf.json",
    "dev:web": "vite",
    "dev:android": "pnpm run prepare:android && node scripts/with-windows-sdk.mjs tauri android dev --config src-tauri/tauri.dev.conf.json",
    "build": "run-p type-check build-only",
    "build-only": "vite build",
    "build:android": "pnpm run prepare:android && node scripts/with-windows-sdk.mjs tauri android build --debug -t aarch64",
    "build:android:apk": "pnpm run prepare:android && node scripts/with-windows-sdk.mjs tauri android build --apk --debug -t aarch64",
    "prepare:android": "node scripts/prepare-android.mjs",
    "tauri": "node scripts/with-windows-sdk.mjs tauri",
    "test": "run-p test:unit test:rust",
    "test:unit": "vitest run",
    "test:rust": "node scripts/with-windows-sdk.mjs cargo test --workspace",
    "test:rust:unit": "node scripts/with-windows-sdk.mjs cargo test --workspace --lib",
    "lint": "run-p eslint lint:rust",
    "eslint": "eslint .",
    "lint:rust": "node scripts/with-windows-sdk.mjs cargo clippy --workspace --all-targets -- -D warnings",
    "type-check": "run-p type-check:app type-check:tests type-check:node",
    "type-check:app": "vue-tsc --noEmit --project tsconfig.app.json",
    "type-check:tests": "vue-tsc --noEmit --project tsconfig.test.json",
    "type-check:node": "vue-tsc --noEmit --project tsconfig.node.json",
    "format": "node scripts/with-windows-sdk.mjs cargo fmt --all",
    "format:check": "node scripts/with-windows-sdk.mjs cargo fmt --all -- --check",
    "check": "run-p type-check lint test",
    "doctor": "node scripts/with-windows-sdk.mjs tauri info"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/node20": "^20.1.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
